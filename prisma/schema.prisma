// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(cuid())
  role Role @default(GUEST)
  email String? @unique
  firstName String
  middleName String?
  lastName String
  suffixName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

}

model Profile {
  id String @id @default(cuid())
  employeeNumber String @unique
  userStatus UserStatus @default(ACTIVE)
  department Department
  position Position
}

enum Department {
  TECHNICAL
  SALES_N_MARKETING
  ADMIN_OR_OPERATIONS
}

enum Position {
  ADMIN_ASSISTANT
  PURCHASING_OFFICER
  JUNIOR_SALES_ASSOCIATE
}

enum Role {
  ADMIN
  HR
  USER
  EMPLOYEE
  GUEST
}

enum Location {
  CEBU
}

enum UserStatus {
  ACTIVE
  RESIGNED
  TERMINATED
  AWOL
}